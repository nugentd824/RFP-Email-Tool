# ── Database (Neon / Vercel Postgres) ───────────────────────────────
# Pooled connection string from your Neon dashboard or Vercel Storage tab.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Auth.js ─────────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 32
AUTH_SECRET=""
# Set to the app's public URL in production, e.g. https://your-app.vercel.app
# (not needed on Vercel — detected automatically)
# AUTH_URL="http://localhost:3000"

# ── Microsoft Entra ID app registration ─────────────────────────────
# Application (client) ID
AUTH_MICROSOFT_ENTRA_ID_ID=""
# Client secret VALUE (not the secret ID)
AUTH_MICROSOFT_ENTRA_ID_SECRET=""
# Replace <tenant-id> with your Directory (tenant) ID
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/<tenant-id>/v2.0"

# ── Access control ──────────────────────────────────────────────────
# Comma-separated list of email addresses allowed to sign in.
# Anyone not on this list is rejected even if they authenticate with Microsoft.
ALLOWED_EMAILS="nugentd8@gmail.com"
